# Required: your Anthropic API key (the agent and its probers run on Claude models).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# AUTOINTEGRATE_MODEL=claude-opus-4-8          # main conversational agent
# AUTOINTEGRATE_PROBE_MODEL=claude-sonnet-4-6  # ingestion probers
# AUTOINTEGRATE_MAX_BUDGET_USD=5               # per-process spend cap
